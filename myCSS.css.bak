*{margin:0}

body{background-color: rgb(0,0,0);
    font-size:20px;
}

img{
 max-width: 100%;
}

body>header{

 background: rgb(250,100,0);
 color: rgb(250,250,0);
}

body>footer{

 background: rgb(100,50,50);
 color: white;
}
body>main{
 position: relative ;
}
body>main>div#logoFace{
  width:50%;
  position: absolute ;
  top: 10px;
  right: 20px;

}
body>main>div#logoFace>img#teacherFace{
  width:60%;
  border:1px solid red ;
 }

body>header>p#lessonName{
  font-size: 1.5em;
  letter-spacing: 0.2em;
  text-align:center;

}
body>footer>p#footerInfo{
  font-size: 0.8em;
  text-align:center;

}